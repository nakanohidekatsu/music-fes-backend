DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

MAIL_FROM=no-reply@example.com
MAIL_TO=admin@example.com
MAIL_API_KEY=your-mail-api-key

JWT_SECRET_KEY=replace-this-with-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Custom Search (定期収集バッチ) ※SerpAPI 使用時は不要
GOOGLE_CSE_API_KEY=your-google-cse-api-key
GOOGLE_CSE_CX=your-custom-search-engine-id

# SerpAPI (https://serpapi.com) 無料プラン: 100回/月
SERPAPI_API_KEY=your-serpapi-key